{
  "name": "pr-evidence-skill",
  "version": "0.1.0",
  "description": "Local-first PR evidence packer for agent-authored release candidates.",
  "type": "module",
  "bin": {
    "pr-evidence": "./src/cli.js"
  },
  "scripts": {
    "test": "node --test",
    "check": "node --check src/*.js test/*.test.js",
    "smoke": "node src/cli.js render fixtures/evidence-pass.json --format markdown",
    "fixture:collect": "node src/cli.js collect --commands fixtures/commands-pass.json --notes fixtures/notes.json --out /tmp/pr-evidence.json",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm run check && npm test && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "agent-skill",
    "pull-request",
    "evidence",
    "release-candidate"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "src",
    "fixtures",
    "docs",
    "SKILL.md",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "CHANGELOG.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/pr-evidence-skill.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/pr-evidence-skill/issues"
  },
  "homepage": "https://github.com/rogerchappel/pr-evidence-skill#readme"
}
